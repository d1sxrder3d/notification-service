# ---- App ----
APP_NAME="Notification Service"
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Max send attempts before notification becomes FAILED.
NOTIFICATION_MAX_ATTEMPTS=3

# ---- Database ----
# Use "postgres" for docker-compose, "sqlite" for a lightweight local run.
DB_TYPE=postgres

# Used only when DB_TYPE=sqlite.
DB_SQLITE_PATH=app/data/notification_service.db

DB_HOST=postgres
DB_PORT=5432
DB_NAME=notification_service
DB_USER=notification_user
DB_PASSWORD=notification_password

# SQLAlchemy engine flags.
DB_ECHO=false
DB_POOL_PRE_PING=true

# ---- Celery / Redis ----
CELERY_BROKER_HOST=redis
CELERY_BROKER_PORT=6379
CELERY_BROKER_DB=0

CELERY_RESULT_HOST=redis
CELERY_RESULT_PORT=6379
CELERY_RESULT_DB=1

CELERY_TASK_DEFAULT_QUEUE=notification_tasks
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
# Pydantic parses this as a tuple.
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC

# ---- RabbitMQ ----
RMQ_PROTOCOL=amqp
RMQ_USER=notification_user
RMQ_PASSWORD=notification_password
RMQ_HOST=rabbitmq
RMQ_PORT=5672

# Use "/" for the default vhost or a plain name like "notifications".
RMQ_VHOST=notifications

RMQ_QUEUE_NAME=notifications
RMQ_PREFETCH_COUNT=1
RMQ_DURABLE=true
RMQ_REQUEUE_ON_ERROR=false

# ---- SMTP ----
SMTP_CHANNEL=email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=notification@example.com
SMTP_PASSWORD=change-me

SMTP_SENDER_EMAIL=notification@example.com
SMTP_SENDER_NAME="Notification Service"

SMTP_USE_TLS=false
SMTP_START_TLS=true

# ---- Observability ----
METRICS_API_PATH=/metrics
METRICS_CELERY_PORT=9101
METRICS_BROKER_PORT=9102

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
